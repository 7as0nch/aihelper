VITE_ENABLE_QR_LOGIN=false
VITE_APP_TITLE=AI 智能助手
VITE_APP_LOGO=/logo.png

# base url
VITE_BASE_URL=/

# AI type: 后端api模式，前端纯净模式
# backend : 纯前端模式：无需登录，只需要接入模型key即可，记录存到本地。
# frontend : 后台模式： 需要登录，接入配套的后台管理。（这里可考虑与宿主完成单点登录配置）
# demo : 样例模式：里面包含各种demo例子。全部使用mock数据。
VITE_AI_TYPE=demo  # backend | frontend | demo 

VITE_TRACKER_ENABLE=true

# 浮球ui展示，支持动态gif图片以及普通ui图片，默认为当前样式。
VITE_FLOAT_BALL_IMAGE=
# 浮窗消息提示随机展示
VITE_FLOAT_BALL_WELCOME_CONTENTS=