FROM node:23.11-alpine AS build-stage

WORKDIR /app

# Install pnpm and dependencies first for better caching
RUN npm install -g pnpm

COPY package.json pnpm-lock.yaml ./
# 移除 --frozen-lockfile 以允许在 lockfile 与 package.json 不完全匹配时仍能安装
RUN pnpm install

# Copy source and build
COPY . .
RUN pnpm run build

FROM nginx:stable-alpine AS production-stage

# Set timezone
RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

# Copy build output and nginx config
COPY --from=build-stage /app/dist /usr/share/nginx/html
COPY ./nginx/prod_conf/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
