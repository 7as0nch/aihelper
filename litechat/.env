# 基础配置
# 是否启用扫码登录
VITE_ENABLE_QR_LOGIN=true
# 应用标题
VITE_APP_TITLE=AI 智能助手
# 应用Logo路径
VITE_APP_LOGO=/logo.png
# 基础路径 / API前缀
VITE_BASE_URL=/api
# API 基础地址 (可选，开发环境生效)
VITE_API_BASE_URL=

# 运行模式配置
# backend : 纯前端模式：无需登录，只需要接入模型key即可，记录存到本地。
# frontend : 后台模式： 需要登录，接入配套的后台管理。（这里可考虑与宿主完成单点登录配置）
# demo : 样例模式：里面包含各种demo例子。全部使用mock数据。
VITE_AI_TYPE=backend

# OpenAI / 模型配置 (仅 Backend 模式或 开发环境使用)
VITE_OPENAI_API_KEY=sk-dc49fec5d27a416f8758ece703aed2ff
VITE_OPENAI_BASE_URL=http://127.0.0.1:6039
VITE_OPENAI_MODEL=deepseek-reasoner

# UI 界面配置 (LiteChat 特性)
# 是否显示顶部Header (true/false)
VITE_SHOW_HEADER=true
# 是否显示底部Footer (true/false)
VITE_SHOW_FOOTER=true
# 底部Footer文本内容
VITE_FOOTER_TEXT=AI 生成的内容可能不准确，请谨慎参考
# 输入框占位符文本
VITE_INPUT_PLACEHOLDER=输入消息，尽管提问...
# 是否显示上传按钮 (true/false)
VITE_SHOW_UPLOAD_BTN=true
# 是否显示语音输入按钮 (true/false)
VITE_SHOW_AUDIO_BTN=false

# 悬浮球配置 (Widget模式)
# 悬浮球自定义图片URL (可选)
VITE_FLOAT_BALL_IMAGE=
# 悬浮球欢迎语内容 (可选)
VITE_FLOAT_BALL_WELCOME_CONTENTS=

# 埋点配置
# 是否启用埋点追踪
VITE_TRACKER_ENABLE=false
